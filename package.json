{
  "name": "imgguard",
  "version": "1.0.0",
  "description": "电商图片敏感词过滤客户端",
  "main": "electron/dev-main.cjs",
  "scripts": {
    "rebuild": "electron-rebuild -f -w sharp",
    "postinstall": "electron-builder install-app-deps",
    "build": "npm run rebuild && tsc && vite build && electron-builder",
    "build:win": "npm run rebuild && tsc && vite build && electron-builder --win",
    "build:mac": "npm run rebuild && tsc && vite build && electron-builder --mac",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.16.0",
    "sharp": "^0.33.5",
    "sql.js": "^1.9.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
